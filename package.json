{
  "name": "openflow-mobile",
  "version": "0.1.0",
  "description": "OpenFlow Mobile — voice-dictation keyboard for iOS + Android with a companion app.",
  "license": "MIT",
  "private": true,
  "main": "index.js",
  "workspaces": [
    "shared"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "npm run typecheck --workspace @openflow/shared && tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "npm run test --workspace @openflow/shared"
  },
  "dependencies": {
    "@openflow/shared": "*",
    "expo": "53.0.0",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.0",
    "@types/react": "~19.0.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.0",
    "typescript": "~5.8.3"
  }
}

{
  "name": "openflow-mobile",
  "version": "0.2.0",
  "description": "OpenFlow Mobile — voice-dictation keyboard for iOS + Android with a companion app.",
  "license": "MIT",
  "private": true,
  "main": "index.js",
  "workspaces": [
    "shared"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "npm run typecheck --workspace @openflow/shared && tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "npm run test --workspace @openflow/shared && jest",
    "test:app": "jest"
  },
  "dependencies": {
    "@bacons/apple-targets": "4.0.7",
    "@openflow/shared": "*",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.18.7",
    "@react-navigation/native": "^7.3.7",
    "expo": "~53.0",
    "expo-audio": "~0.4.9",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.8",
    "expo-file-system": "~18.1.11",
    "expo-linking": "~7.1.7",
    "expo-secure-store": "~14.2.4",
    "expo-speech": "~13.1.7",
    "expo-speech-recognition": "^2.1.5",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.0",
    "@types/react": "~19.0.10",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.0",
    "prettier": "^3.5.3",
    "react-test-renderer": "^19.0.0",
    "ts-jest": "^29.3.0",
    "typescript": "~5.8.3"
  }
}

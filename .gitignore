# dependencies
node_modules/

# Expo / generated native projects (CNG — not committed).
# Anchored to the repo root so they DON'T also ignore local Expo modules' own
# native code (e.g. modules/settings-bridge/android, .../ios), which IS committed.
.expo/
dist/
dist-ios/
dist-android/
web-build/
/ios/
/android/

# @bacons/apple-targets writes this into the target dir at prebuild time from
# expo-target.config.js — regenerated every prebuild, so it is not committed.
targets/**/generated.entitlements

# native / build artifacts
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# testing
coverage/

# misc
.DS_Store
*.log
npm-debug.*
yarn-error.*
.env
.env.local
*.tsbuildinfo
